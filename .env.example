# Example environment variables for MCP Proxy Server
# Copy this file to .env and fill in your values

# ============================================================================
# SECURITY SETTINGS (REQUIRED)
# ============================================================================

# Bearer token for authentication - REQUIRED unless auth is explicitly disabled
# Generate a secure token with: openssl rand -hex 32
MCP_BEARER_TOKEN=your-secure-token-here

# To disable authentication (NOT RECOMMENDED for production)
# MCP_DISABLE_AUTH=true

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Path to MCP configuration file
# Default: mcp_config.json
# MCP_CONFIG_PATH=/app/mcp_config.json

# Host address to bind to
# Default: 0.0.0.0 (all interfaces)
# MCP_HOST=0.0.0.0

# Port number to bind to  
# Default: 8080
# MCP_PORT=8080

# Optional URL path prefix for all endpoints
# Example: MCP_PATH_PREFIX=e9415487-f3b9-4186-ade3-da8586ddf96b
# Creates endpoints at: /e9415487-f3b9-4186-ade3-da8586ddf96b/mcp/{server}/
# MCP_PATH_PREFIX=

# ============================================================================
# RESILIENCE & MONITORING
# ============================================================================

# Maximum retries for config loading
# Default: 3
# MCP_MAX_RETRIES=3

# Initial delay between restarts in seconds
# Default: 5
# MCP_RESTART_DELAY=5

# Enable live configuration reloading
# Default: false
# MCP_LIVE_RELOAD=true

# ============================================================================
# MCP SERVER API KEYS
# ============================================================================

# NocoDB MCP Server
# NOCODB_MCP_URL=https://your-nocodb-instance.com/mcp/YOUR_WORKSPACE_ID
# NOCODB_MCP_TOKEN=your_nocodb_mcp_token_here

# SearXNG Search Instance
# SEARXNG_INSTANCES=http://localhost:8082

# Fetch MCP Server URL
# FETCH_MCP_URL=http://localhost:11235/mcp/sse

# API keys for specific MCP servers (referenced in mcp_config.json)
# Example: Firecrawl web search
# API_KEY_FIRECRAWL=your_firecrawl_api_key

# Example: Brave search  
# BRAVE_API_KEY=your_brave_api_key

# ============================================================================
# MCP SERVER DATA PATHS
# ============================================================================

# Data directories for MCP servers (referenced in mcp_config.json)
# Example: Basic memory server storage (Obsidian)
BASIC_MEMORY_HOME=/data/obsidian
